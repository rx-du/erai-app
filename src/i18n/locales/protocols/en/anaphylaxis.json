{
  "id": "anaphylaxis",
  "title": "Anaphylaxis",
  "category": [
    {
      "name": "Severity Assessment",
      "sections": [
        {
          "title": "Anaphylaxis Can Rapidly Cause",
          "type": "list",
          "items": [
            "Airway swelling (can block breathing)",
            "Severe difficulty breathing",
            "Drop in blood pressure (shock)",
            "Loss of consciousness",
            "Death if untreated"
          ]
        },
        {
          "title": "Mild Reaction",
          "type": "list",
          "items": ["Localized hives", "Mild itching", "Nasal congestion", "Mild GI upset"]
        },
        {
          "title": "Moderate Reaction",
          "type": "list",
          "items": ["Generalized hives", "Mild airway swelling", "Vomiting", "Anxiety"]
        },
        {
          "title": "Notes",
          "type": "text",
          "content": "Monitor closely, consider antihistamines. Prepare epinephrine, close monitoring."
        },
        {
          "title": "Severe Anaphylaxis",
          "type": "text",
          "content": "Requires immediate epinephrine injection and emergency medical support."
        }
      ]
    },
    {
      "name": "Epinephrine Dose",
      "sections": [
        {
          "title": "There are no absolute contraindications to epinephrine in anaphylaxis.",
          "type": "list",
          "items": ["Adult: 0.3–0.5mg/IM", "Child: 0.1mg/IM (max 0.3mg)", "Infant: 0.1–0.15mg/IM"]
        }
      ]
    }
  ],
  "steps": [
    {
      "id": "anaphylaxis_protocol",
      "title": "Anaphylaxis Protocol",
      "category": "Allergic Emergencies",
      "severity": "critical",
      "steps": [
        {
          "id": 1,
          "title": "Recognize Anaphylaxis",
          "subtitle": "Suspect anaphylaxis if there is acute onset (minutes–hours) of:\n\n• Skin/Mucosal: hives, flushing, itching, angioedema (lips, tongue, throat)\n• Respiratory: wheeze, stridor, shortness of breath, throat tightness\n• Cardiovascular: hypotension, dizziness, syncope\n• Gastrointestinal: vomiting, diarrhea, abdominal pain\n• Neurologic: feeling of impending doom\n\nCommon triggers:\n\n• Foods (nuts, shellfish, milk, eggs)\n• Medications (penicillin, NSAIDs)\n• Insect stings\n• Latex",
          "timeframe": "Immediate",
          "type": "instruction",
          "video": null,
          "status": "pending"
        },
        {
          "id": 2,
          "title": "Call Emergency Services",
          "subtitle": "Call 911 immediately for suspected anaphylaxis",
          "timeframe": "Within 1 minute",
          "type": "action",
          "icon": "phone",
          "actionText": "Call 911",
          "status": "pending",
          "shouldDisplayEmergencyCall": true,
          "video": null
        },
        {
          "id": 3,
          "title": "Administer Epinephrine",
          "subtitle": "Use EpiPen or epinephrine auto-injector if available (DO NOT DELAY)",
          "timeframe": "Within 2 minutes",
          "type": "instruction",
          "video": null,
          "link": "epinephrine_dose",
          "status": "pending",
          "shouldDisplayEpinephineDose": true,
          "image": "anaphylaxis_epinephrine.png"
        },
        {
          "id": 4,
          "title": "Position Patient",
          "subtitle": "Place patient Supine (flat on their back, facing upward) with legs elevated (unless respiratory distress).",
          "timeframe": "After epinephrine",
          "type": "instruction",
          "video": null,
          "status": "pending"
        },
        {
          "id": 5,
          "title": "Monitor Breathing",
          "subtitle": "Continuously monitor airway and breathing",
          "timeframe": "Ongoing",
          "type": "monitor",
          "status": "pending"
        },
        {
          "id": 6,
          "title": "Prepare Second Dose",
          "subtitle": "Be ready to give second epinephrine dose if needed",
          "timeframe": "If needed",
          "type": "alert",
          "link": "epinephrine_dose",
          "status": "pending",
          "shouldDisplayEpinephineDose": true
        }
      ]
    }
  ]
}
